generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Teams ────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String   @map("display_name")
  email       String   @unique
  password    String
  role        String   @default("developer")
  managerId   String?  @map("manager_id")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  manager      User?  @relation("UserManager", fields: [managerId], references: [id])
  managedUsers User[] @relation("UserManager")
  chatThreads  ChatThread[] @relation("UserChatThreads")
  chatRooms    ChatRoom[]   @relation("UserChatRooms")

  teamMemberships TeamMembership[]
  projectGrants   ProjectGrant[]   @relation("GrantedByUser")
  sessions        Session[]
  mcpTokens       McpToken[]
  ownedProjects   Project[]        @relation("ProjectOwner")

  createdTasks     Task[]          @relation("TaskCreator")
  updatedTasks     Task[]          @relation("TaskLastEditor")
  createdPhases    Phase[]         @relation("PhaseCreator")
  updatedPhases    Phase[]         @relation("PhaseLastEditor")
  createdDecisions Decision[]      @relation("DecisionCreator")
  updatedDecisions Decision[]      @relation("DecisionLastEditor")
  createdMemories  MemoryEntry[]   @relation("MemoryCreator")
  updatedMemories  MemoryEntry[]   @relation("MemoryLastEditor")
  activityEvents   ActivityEvent[] @relation("ActivityActor")

  invitedTeamInvites  TeamInvite[] @relation("InviteInviter")
  acceptedTeamInvites TeamInvite[] @relation("InviteAccepter")

  projectArchives ProjectUserArchive[]

  chatbotConfig ChatbotConfig?

  @@map("users")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memberships TeamMembership[]
  invites     TeamInvite[]
  projects     Project[]
  agentConfigs AgentConfig[]

  @@map("teams")
}


model TeamInvite {
  id                String    @id @default(cuid())
  teamId            String    @map("team_id")
  email             String
  role              String    @default("member")
  token             String    @unique
  status            String    @default("pending")
  invitedByUserId   String    @map("invited_by_user_id")
  expiresAt         DateTime  @map("expires_at")
  acceptedAt        DateTime? @map("accepted_at")
  acceptedByUserId  String?   @map("accepted_by_user_id")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  team        Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy   User  @relation("InviteInviter", fields: [invitedByUserId], references: [id])
  acceptedBy  User? @relation("InviteAccepter", fields: [acceptedByUserId], references: [id])

  @@index([teamId, status])
  @@index([email, status])
  @@map("team_invites")
}

model TeamMembership {
  id     String @id @default(cuid())
  teamId String @map("team_id")
  userId String @map("user_id")
  role   String @default("member")
  status String @default("active")

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@map("team_memberships")
}

// ── Auth & Sessions ──────────────────────────────────

model Session {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

// ── Projects ─────────────────────────────────────────

model Project {
  id                     String    @id @default(cuid())
  name                   String
  slug                   String    @unique
  description            String?
  status                 String    @default("active")
  ownerTeamId            String    @map("owner_team_id")
  ownerUserId            String?   @map("owner_user_id")
  homeUrl                String?   @map("home_url")
  thumbnailUrl           String?   @map("thumbnail_url")
  thumbnailUpdatedAt     DateTime? @map("thumbnail_updated_at")
  thumbnailExpiresAt     DateTime? @map("thumbnail_expires_at")
  thumbnailManualUpload  Boolean   @default(false) @map("thumbnail_manual_upload")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  ownerTeam         Team                  @relation(fields: [ownerTeamId], references: [id])
  ownerUser         User?                 @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  phases            Phase[]
  tasks             Task[]
  memoryEntries     MemoryEntry[]
  decisions         Decision[]
  projectGrants     ProjectGrant[]
  codeRepositories  CodeRepository[]
  domainGroups      DomainGroup[]
  userArchives      ProjectUserArchive[]

  @@map("projects")
}


model ProjectUserArchive {
  projectId  String   @map("project_id")
  userId     String   @map("user_id")
  archivedAt DateTime @default(now()) @map("archived_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_user_archives")
}

model Phase {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  decisionId      String?   @map("decision_id")
  title           String
  description     String?
  orderIndex      Int       @default(0) @map("order_index")
  status          String    @default("planned")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  decision  Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("PhaseCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("PhaseLastEditor", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  tasks     Task[]

  @@map("phases")
}

model Task {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  phaseId         String    @map("phase_id")
  title           String
  description     String?
  status          String    @default("todo")
  priority        String    @default("medium")
  assigneeId      String?   @map("assignee_id")
  dueDate         DateTime? @map("due_date")
  completionNotes String?   @map("completion_notes")
  completedAt     DateTime? @map("completed_at")
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase     Phase   @relation(fields: [phaseId], references: [id], onDelete: Restrict)
  createdBy User?   @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?   @relation("TaskLastEditor", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

// ── Decisions ────────────────────────────────────────

model Decision {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  title           String
  summary         String
  rationale       String?
  outcome         String?
  status          String    @default("open")
  impactLevel     String    @default("medium") @map("impact_level")
  resolvedAt      DateTime? @map("resolved_at")
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("DecisionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?   @relation("DecisionLastEditor", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  phases    Phase[]

  @@map("decisions")
}

// ── Activity Events ──────────────────────────────────

model ActivityEvent {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  actorType   String   @map("actor_type")
  actorId     String   @map("actor_id")
  actorUserId String?  @map("actor_user_id")
  mcpTokenId  String?  @map("mcp_token_id")
  source      String   @default("web")
  eventType   String   @map("event_type")
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([eventType])
  @@index([createdAt])
  @@index([actorUserId])
  @@index([mcpTokenId])
  @@map("activity_events")
}

// ── Memory ───────────────────────────────────────────

model MemoryEntry {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  type            String
  title           String
  body            String?
  createdByUserId String?  @map("created_by_user_id")
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("MemoryCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?   @relation("MemoryLastEditor", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("memory_entries")
}

// ── Grants ───────────────────────────────────────────

model ProjectGrant {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  subjectType     String   @map("subject_type")
  subjectId       String   @map("subject_id")
  grantType       String   @map("grant_type")
  grantedByUserId String?  @map("granted_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  grantedBy User?   @relation("GrantedByUser", fields: [grantedByUserId], references: [id])

  @@map("project_grants")
}

// ── MCP Tokens ───────────────────────────────────────

model McpToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name      String
  tokenHash String    @unique @map("token_hash")
  scopes    String[]  @default([]) @map("scopes")
  status    String    @default("active")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@map("mcp_tokens")
}

// ── CodeFlow ─────────────────────────────────────────

model CodeRepository {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  name          String
  repoUrl       String?  @map("repo_url")
  provider      String   @default("manual")
  defaultBranch String   @default("main") @map("default_branch")
  scanIntervalH Int?     @map("scan_interval_h")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project   Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots ArchitectureSnapshot[]

  @@map("code_repositories")
}

model ArchitectureSnapshot {
  id            String    @id @default(cuid())
  repositoryId  String    @map("repository_id")
  projectId     String    @map("project_id")
  commitHash    String?   @map("commit_hash")
  status        String    @default("pending")
  scanType      String    @default("manual") @map("scan_type")
  errorMessage  String?   @map("error_message")
  nodeCount     Int       @default(0) @map("node_count")
  edgeCount     Int       @default(0) @map("edge_count")
  triggeredById String?   @map("triggered_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  repository     CodeRepository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([repositoryId, createdAt])
  @@map("architecture_snapshots")
}

model DomainGroup {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  color     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("domain_groups")
}


model GraphSyncEvent {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  entityType    String    @map("entity_type")
  entityId      String    @map("entity_id")
  op            String
  payload       Json
  attempts      Int       @default(0)
  status        String    @default("pending")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")
  nextAttemptAt DateTime? @map("next_attempt_at")

  @@index([status, nextAttemptAt])
  @@index([projectId, status])
  @@index([entityType, entityId])
  @@map("graph_sync_events")
}


model ChatbotConfig {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  provider        String
  apiKeyEncrypted String?  @map("api_key_encrypted")
  ollamaBaseUrl   String?  @map("ollama_base_url")
  modelName       String   @map("model_name")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chatbot_configs")
}

// ── life-OS: Agent definitions ───────────────────────

model AgentConfig {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  capability   String
  runtime      String   @default("api") // api | cli | local
  provider     String                   // anthropic | openai | ollama | claude-code | codex
  model        String
  systemPrompt String?  @map("system_prompt")
  description  String?
  avatarUrl    String?  @map("avatar_url")
  doesText     String?  @map("does_text")
  doesNotText  String?  @map("does_not_text")
  enabled      Boolean  @default(true)
  trustTier    String   @default("restricted") @map("trust_tier") // restricted | dev | sysadmin
  ownerUserId  String?  @map("owner_user_id")
  ownerTeamId  String   @map("owner_team_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ownerTeam Team @relation(fields: [ownerTeamId], references: [id], onDelete: Cascade)

  @@index([ownerTeamId])
  @@map("agent_configs")
}

// ── life-OS: agent chat threads + history ────────────

model ChatThread {
  id            String    @id @default(cuid())
  ownerUserId   String    @map("owner_user_id")
  agentSlug     String    @map("agent_slug")
  title         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastMessageAt DateTime? @map("last_message_at")

  ownerUser User          @relation("UserChatThreads", fields: [ownerUserId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@unique([ownerUserId, agentSlug])
  @@index([ownerUserId])
  @@map("chat_threads")
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String   @map("thread_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("chat_messages")
}

model ChatRoom {
  id            String    @id @default(cuid())
  kind          String    @default("direct") // direct | group
  title         String?
  ownerUserId   String    @map("owner_user_id")
  projectId     String?   @map("project_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastMessageAt DateTime? @map("last_message_at")

  summaryText          String?   @map("summary_text")
  summaryUpToMessageId String?   @map("summary_up_to_message_id")
  summaryTokens        Int?      @map("summary_tokens")
  summaryUpdatedAt     DateTime? @map("summary_updated_at")

  ownerUser    User              @relation("UserChatRooms", fields: [ownerUserId], references: [id], onDelete: Cascade)
  participants ChatParticipant[]
  messages     RoomMessage[]

  @@index([ownerUserId])
  @@map("chat_rooms")
}

model ChatParticipant {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  kind      String   // user | agent
  refId     String   @map("ref_id") // userId or agent slug
  createdAt DateTime @default(now()) @map("created_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, kind, refId])
  @@index([roomId])
  @@map("chat_participants")
}

model RoomMessage {
  id         String   @id @default(cuid())
  roomId     String   @map("room_id")
  senderKind String   @map("sender_kind") // user | agent
  senderId   String   @map("sender_id")   // userId or agent slug
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([roomId, createdAt])
  @@map("room_messages")
}

model AgentUserCredential {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  provider  String
  accountId String   @map("account_id")
  encToken  String   @map("enc_token")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, provider])
  @@index([userId])
  @@map("agent_user_credentials")
}

// ── life-OS: scheduled activities + calendar ─────────

enum ScheduleKind {
  cron
  once
  interval
}

enum ActivityStatus {
  active
  paused
  expired
  done
}

enum RunStatus {
  pending
  running
  ok
  error
  skipped
}

model ScheduledActivity {
  id            String   @id @default(cuid())
  userId        String         @map("user_id")
  projectId     String?        @map("project_id")
  title         String
  kind          ScheduleKind
  cronExpr      String?        @map("cron_expr")          // kind=cron (5-field, tz-aware)
  runAt         DateTime?      @map("run_at")             // kind=once
  everyMs       Int?           @map("every_ms")           // kind=interval
  tz            String   @default("Europe/Rome")
  agentSlug     String         @map("agent_slug")         // responder
  promptTemplate String        @map("prompt_template")    // what to ask the agent each run
  deliveryRoomId String?       @map("delivery_room_id")   // room to append into (auto/direct if null)
  notify        Boolean  @default(true) // push via OpenClaw bridge
  status        ActivityStatus @default(active)
  nextRunAt     DateTime?      @map("next_run_at")
  lastRunAt     DateTime?      @map("last_run_at")
  expiresAt     DateTime?      @map("expires_at")
  createdBy     String         @map("created_by")         // "user:<id>" | "agent:<slug>"
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  runs          ScheduledActivityRun[]
  @@index([status, nextRunAt])
  @@index([userId])
  @@map("scheduled_activities")
}

model ScheduledActivityRun {
  id              String   @id @default(cuid())
  activityId      String            @map("activity_id")
  activity        ScheduledActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  firedAt         DateTime @default(now()) @map("fired_at")
  status          RunStatus @default(pending)
  outputMessageId String?          @map("output_message_id") // roomMessage produced
  outputPreview   String?          @map("output_preview")    // first ~280 chars, for calendar/notif
  error           String?
  durationMs      Int?             @map("duration_ms")
  @@index([activityId, firedAt])
  @@map("scheduled_activity_runs")
}
