# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://roadboard:roadboard@localhost:5433/roadboard

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ── Services ──────────────────────────────────────────
CORE_API_PORT=3001
AUTH_ACCESS_PORT=3002
WORKER_JOBS_PORT=3003
LOCAL_SYNC_PORT=3004
MCP_HTTP_PORT=3005

# ── MCP ───────────────────────────────────────────────
# URL pubblica mostrata nella guida MCP della web-app (/mcp-guide).
# Deve essere raggiungibile dai client (Claude Code, Zed, VS Code).
NEXT_PUBLIC_MCP_URL=http://localhost:3005/mcp

# ── Local sync ────────────────────────────────────────
JOURNAL_DB_PATH=.agent/journal.db

# ── Release gate ──────────────────────────────────────
# Shared secret between GitHub Actions (notify-release workflow) and core-api.
# Both must hold the same value. Generate with: openssl rand -hex 32
RELEASE_WEBHOOK_SECRET=change-me
# URL of the Deploy workflow on GitHub. Kept as fallback (not used by the banner anymore).
DEPLOY_WORKFLOW_URL=https://github.com/Maless88/RB/actions/workflows/deploy.yml
# Fine-grained PAT used by core-api to trigger workflow_dispatch of the deploy workflow.
# Scope required: Actions=write on the repo below (Contents=read also needed if the repo is private).
GITHUB_DISPATCH_TOKEN=
GITHUB_REPO=Maless88/RB
GITHUB_DEPLOY_WORKFLOW=deploy.yml
GITHUB_DEPLOY_REF=main

# ── Environment ───────────────────────────────────────
NODE_ENV=development
