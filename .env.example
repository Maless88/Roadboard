# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://roadboard:roadboard@localhost:5433/roadboard

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ── Services ──────────────────────────────────────────
CORE_API_PORT=3001
AUTH_ACCESS_PORT=3002
WORKER_JOBS_PORT=3003
LOCAL_SYNC_PORT=3004
MCP_HTTP_PORT=3005

# ── MCP ───────────────────────────────────────────────
# URL pubblica mostrata nella guida MCP della web-app (/mcp-guide).
# Deve essere raggiungibile dai client (Claude Code, Zed, VS Code).
NEXT_PUBLIC_MCP_URL=http://localhost:3005/mcp
# Public core-api URL used by the browser to load static assets (thumbnails).
NEXT_PUBLIC_CORE_API_URL=http://localhost:3001

# ── Thumbnails ────────────────────────────────────────
THUMBNAIL_TTL_HOURS=24
# THUMBNAIL_UPLOAD_DIR=  # default: apps/core-api/uploads/thumbnails
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ── Local sync ────────────────────────────────────────
JOURNAL_DB_PATH=.agent/journal.db

# ── Release / self-hosted deploy ──────────────────────
# Self-hosted per-host deploy: each core-api instance compares BUILD_SHA
# against the latest commit on GitHub and, on user click, runs
# `git pull && docker compose up -d --build` against the local host.
# Prerequisites on the host: the repo checked out at $ROADBOARD_HOST_REPO_PATH
# and the docker.sock mount already configured in compose.

GITHUB_REPO=Maless88/Roadboard
# Optional PAT (Contents=read). Raises the GitHub REST rate-limit from
# 60/hr (unauth) to 5000/hr. Required for private repos.
GITHUB_READ_TOKEN=
# Branch tracked for "version available" detection and pulled on deploy.
ROADBOARD_DEPLOY_BRANCH=main
# Host-side path of the cloned repo. Mounted into core-api at /opt/roadboard.
# Default `../..` works for local dev (repo root from infra/docker/); in prod
# set to the absolute path, e.g. /opt/roadboard.
ROADBOARD_HOST_REPO_PATH=../..

# ── CodeFlow / Atlas projection (CF-GDB-03b — Stage 2) ───────────
# When 'true', GraphService stops calling Memgraph inline and instead
# enqueues outbox events; the GraphProjectionService in worker-jobs
# applies them to Memgraph asynchronously with retry + dead-letter.
# Default 'false' = legacy Stage 1A behaviour (inline best-effort mirror).
GRAPH_SYNC_USE_OUTBOX=false

# ── CodeFlow / Atlas read-path swap (CF-GDB-03b — Stage B) ───────
# When 'true', GraphService.getImpact() serves the impact query from
# Memgraph via Cypher reverse-BFS instead of Postgres. On any Cypher
# error the call automatically falls back to the Postgres path.
# Default 'false' = Postgres-only (zero regression in dev/prod).
# The integration test suite turns it on via .env.test.
GRAPH_READ_USE_MEMGRAPH_IMPACT=false

# ── CodeFlow / Atlas write-path swap (CF-GDB-03b — Stage D) ──────
# When 'true', GraphService + DomainGroupsService perform graph writes
# (node/edge/link/annotation/domain-group, plus resetProject) directly
# on Memgraph via Cypher instead of Postgres. Audit events and the
# non-graph codeRepository cleanup stay on Postgres. Fail-closed: a
# Cypher error propagates and fails the write API. Default 'false' =
# Postgres-primary (zero regression in dev/prod).
GRAPH_WRITE_USE_MEMGRAPH=false

# ── Chatbot ───────────────────────────────────────────
# 32-byte base64 key used to encrypt provider API keys at rest (AES-256-GCM).
# Generate with: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
CHATBOT_KEY=replace-with-32-byte-base64-key

# ── Seed ──────────────────────────────────────────────
# Required when running `pnpm db:seed`. Never use a real/shared password here.
SEED_ADMIN_PASSWORD=change-me-before-seeding

# ── Environment ───────────────────────────────────────
NODE_ENV=development
